APP_NAME="SafePulse"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# In Codespaces this URL auto-updates; in production set to your EC2 domain
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (zero config for Codespaces / local dev)
DB_CONNECTION=sqlite
# DB_DATABASE is relative to the backend root
DB_DATABASE=/workspaces/safepulse/backend/database/database.sqlite

# ── To switch to MySQL (e.g. AWS RDS) later, comment out SQLite above and use:
# DB_CONNECTION=mysql
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_PORT=3306
# DB_DATABASE=safepulse
# DB_USERNAME=admin
# DB_PASSWORD=your_password_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the API.
# In Codespaces, Vite runs on port 5173 of the forwarded URL.
# In production, set to your Amplify domain.
FRONTEND_URL=http://localhost:5173

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
